{
  "name": "otis",
  "version": "1.0.0",
  "description": "An elegant dark theme for gnome",
  "main": "index.js",
  "scripts": {
    "watch-shell": "find ~/Repositories/Andromeda-gtk/gnome-shell -name '*.scss' | entr ~/Repositories/Andromeda-gtk/scripts/build-shell.sh",
    "watch-gtk-4.0": "find ~/Repositories/Andromeda-gtk/gtk-4.0 -name '*.scss' | entr ~/Repositories/Andromeda-gtk/scripts/build-gtk-4.0.sh",
    "watch-gtk-3.0": "find ~/Repositories/Andromeda-gtk/gtk-3.0 -name '*.scss' | entr ~/Repositories/Andromeda-gtk/scripts/build-gtk-3.0.sh",
    "watch-gtk": "find ~/Repositories/Andromeda-gtk/ -name '*.scss' | entr ~/Repositories/Andromeda-gtk/scripts/build-gtk.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EliverLara/Otis.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/EliverLara/Otis/issues"
  },
  "homepage": "https://github.com/EliverLara/Otis#readme",
  "dependencies": {
    "gulp": "^4.0.0",
    "gulp-exec": "^5.0.0",
    "gulp-sass": "^4.0.2"
  }
}
